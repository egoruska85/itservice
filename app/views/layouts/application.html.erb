<!DOCTYPE html>
<html class="h-100">
  <head>
    <% if @organization&.logo&.attached? %>
      <%= favicon_link_tag rails_blob_url(@organization.logo) %>
    <% end %>
    <title><%= @organization&.name || "Default Title" %></title>
    <meta name="viewport" content="width=device-width,initial-scale=1">
    <%= csrf_meta_tags %>
    <%= csp_meta_tag %>

    <%= stylesheet_link_tag "application", "data-turbo-track": "reload" %>
    <%= javascript_importmap_tags %>

    <%# Подключение кастомных стилей и скриптов slide %>
    <%= stylesheet_link_tag 'slide', media: 'all', 'data-turbo-track': 'reload' %>
    <%= javascript_include_tag 'slide', 'data-turbo-track': 'reload' %>

    <style>
      body {
        background-image: url('/images/digitization-g47f47bac3_1920.jpg');
        background-repeat: no-repeat;
        background-attachment: fixed;
        background-size: cover;
      }
    </style>
  </head>

  <body class="d-flex flex-column h-100">
    <%# Контент страницы обязательно должен быть внутри контейнера, если вы используете Bootstrap %>
    <div id="flash-notifications" class="flash-container">
  <% flash.each do |type, message| %>
    <% alert_class = type == 'notice' ? 'success' : 'danger' %>
    <% icon_class = type == 'notice' ? 'bi-check-circle-fill' : 'bi-exclamation-triangle-fill' %>

    <div class="alert alert-<%= alert_class %> alert-dismissible fade show shadow shadow-lg mb-3 custom-alert" role="alert">
      <div class="d-flex align-items-center">
        <i class="bi <%= icon_class %> me-2"></i>
        <div><%= message %></div>
      </div>
      <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
    </div>
  <% end %>
</div>
    <main class="container my-4">
      <%= yield %>
    </main>

    <nav class="navbar bg-body-tertiary mt-auto" style="background: linear-gradient(to left, rgba(255, 255, 255, 1), rgba(255, 255, 255, 0)); height: 53px;">
      <div class="container">
        <ul class="nav ms-auto">
          <li class="nav-item">
            <%= @organization&.name %> &copy; <%= Time.current.year %> <%= t('footer.rights') %>
          </li>
        </ul>
      </div>
    </nav>

  </body>
</html>
