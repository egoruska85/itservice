<div class="card shadow-sm">
  <div class="card-header bg-light py-2">
    <h6 class="card-title mb-0 text-secondary fw-bold" style="font-size: 0.9rem;">
      <i class="bi bi-building me-1"></i> Форма ввода реквизитов
    </h6>
  </div>

  <div class="card-body p-3">
    <%= form_with model: @companydetail, url: create_company_details_organizations_path, method: :post do |f| %>

      <div class="mb-2">
        <%= f.label :name_organization, "Название организации", class: "form-label small mb-1 text-muted fw-semibold" %>
        <%= f.text_field :name_organization, class: "form-control form-control-sm #{'is-invalid' if @companydetail.errors[:name_organization].any?}", placeholder: "ООО 'Ромашка'" %>
        <% if @companydetail.errors[:name_organization].any? %>
          <div class="invalid-feedback" style="font-size: 0.75rem;"><%= @company_detail.errors[:name_organization].first %></div>
        <% end %>
      </div>

      <div class="row g-2 mb-2">
        <div class="col-6">
          <%= f.label :inn, "ИНН", class: "form-label small mb-1 text-muted fw-semibold" %>
          <%= f.text_field :inn, class: "form-control form-control-sm #{'is-invalid' if @companydetail.errors[:inn].any?}", placeholder: "10 или 12 цифр" %>
          <% if @companydetail.errors[:inn].any? %>
            <div class="invalid-feedback" style="font-size: 0.75rem;"><%= @company_detail.errors[:inn].first %></div>
          <% end %>
        </div>
        <div class="col-6">
          <%= f.label :kpp, "КПП", class: "form-label small mb-1 text-muted fw-semibold" %>
          <%= f.text_field :kpp, class: "form-control form-control-sm #{'is-invalid' if @companydetail.errors[:kpp].any?}", placeholder: "9 цифр" %>
          <% if @companydetail.errors[:kpp].any? %>
            <div class="invalid-feedback" style="font-size: 0.75rem;"><%= @company_detail.errors[:kpp].first %></div>
          <% end %>
        </div>
      </div>

      <div class="mb-2">
        <%= f.label :recipient_bank_name, "Банк получателя", class: "form-label small mb-1 text-muted fw-semibold" %>
        <%= f.text_field :recipient_bank_name, class: "form-control form-control-sm #{'is-invalid' if @companydetail.errors[:recipient_bank_name].any?}", placeholder: "АО 'Альфа-Банк'" %>
        <% if @companydetail.errors[:recipient_bank_name].any? %>
          <div class="invalid-feedback" style="font-size: 0.75rem;"><%= @company_detail.errors[:recipient_bank_name].first %></div>
        <% end %>
      </div>

      <div class="row g-2 mb-2">
        <div class="col-4">
          <%= f.label :bik, "БИК", class: "form-label small mb-1 text-muted fw-semibold" %>
          <%= f.text_field :bik, class: "form-control form-control-sm #{'is-invalid' if @companydetail.errors[:bik].any?}", placeholder: "9 цифр" %>
          <% if @companydetail.errors[:bik].any? %>
            <div class="invalid-feedback" style="font-size: 0.75rem;"><%= @companydetail.errors[:bik].first %></div>
          <% end %>
        </div>
        <div class="col-8">
          <%= f.label :correspondent_account_number, "Корр. счет", class: "form-label small mb-1 text-muted fw-semibold" %>
          <%= f.text_field :correspondent_account_number, class: "form-control form-control-sm #{'is-invalid' if @companydetail.errors[:correspondent_account_number].any?}", placeholder: "301..." %>
          <% if @companydetail.errors[:correspondent_account_number].any? %>
            <div class="invalid-feedback" style="font-size: 0.75rem;"><%= @companydetail.errors[:correspondent_account_number].first %></div>
          <% end %>
        </div>
      </div>

      <div class="mb-2">
        <%= f.label :current_account, "Расчетный счет", class: "form-label small mb-1 text-muted fw-semibold" %>
        <%= f.text_field :current_account, class: "form-control form-control-sm #{'is-invalid' if @companydetail.errors[:current_account].any?}", placeholder: "407..." %>
        <% if @companydetail.errors[:current_account].any? %>
          <div class="invalid-feedback" style="font-size: 0.75rem;"><%= @companydetail.errors[:current_account].first %></div>
        <% end %>
      </div>

      <div class="mb-3">
        <%= f.label :additionally, "Дополнительная информация", class: "form-label small mb-1 text-muted fw-semibold" %>
        <%= f.text_area :additionally, class: "form-control form-control-sm", rows: 2, placeholder: "Примечания..." %>
      </div>

      <div class="d-flex justify-content-end">
        <%= f.submit "Сохранить реквизиты", class: "btn btn-primary btn-sm px-3 fw-semibold", style: "font-size: 0.8rem;" %>
      </div>
    <% end %>
  </div>
</div>
